<!-- Window and navigation styles for the configurator dark theme.
     These styles control the outer chrome and tab navigation appearance. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark background for the entire tab control area -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="#16213E"/>
        <Setter Property="BorderBrush" Value="#0F3460"/>
    </Style>

    <!-- Tab item styling: dark inactive, highlighted red when selected -->
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#16213E"/>
        <Setter Property="Foreground" Value="#8899AA"/>
        <Setter Property="BorderBrush" Value="#0F3460"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,8"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1A1A2E"/>
                <Setter Property="Foreground" Value="#E94560"/>
                <Setter Property="BorderBrush" Value="#E94560"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
