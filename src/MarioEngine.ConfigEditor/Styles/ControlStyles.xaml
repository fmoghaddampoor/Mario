<!-- Reusable container and input control styles for the configurator.
     Group boxes group related settings, text fields follow the dark theme. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- GroupBox: dark bordered container for grouping related settings together -->
    <Style x:Key="GroupBox" TargetType="Border">
        <Setter Property="Background" Value="#16213E"/>
        <Setter Property="BorderBrush" Value="#0F3460"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- FieldLabel: subdued label text for form fields above sliders or text boxes -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#8899AA"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- DarkTextBox: text input field with dark background and blue border -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="BorderBrush" Value="#0F3460"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- DarkCombo: dropdown selector with dark background -->
    <Style x:Key="DarkCombo" TargetType="ComboBox">
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="BorderBrush" Value="#0F3460"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

</ResourceDictionary>
