<!-- Button styles for the configurator footer actions.
     Primary action buttons are red, secondary/reset buttons are dark blue. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- BaseButton: shared template for all configurator buttons.
         All buttons have no border, rounded corners, and a hand cursor. -->
    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.85"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PrimaryActionButton: red button for primary actions like Save and Close -->
    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="#E94560"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- SecondaryButton: dark button for secondary actions like Reset -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="#333355"/>
    </Style>

</ResourceDictionary>
