<UserControl x:Class="MarioEngine.ConfigEditor.Views.InputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="SENSITIVITY" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <TextBlock Text="Horizontal Sensitivity" Style="{StaticResource FieldLabel}"/>
                <Slider Value="{Binding HorizontalSensitivityPercent}" Minimum="25" Maximum="200" TickFrequency="25"/>
                <TextBlock Text="Vertical Sensitivity" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                <Slider Value="{Binding VerticalSensitivityPercent}" Minimum="25" Maximum="200" TickFrequency="25"/>
                <TextBlock Text="Dead Zone" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                <Slider Value="{Binding DeadZonePercent}" Minimum="5" Maximum="30" TickFrequency="5"/>
            </StackPanel>
        </Border>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="FEATURES" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <CheckBox Content="Auto-Run (always sprint)" IsChecked="{Binding AutoRun}" Margin="0,4"/>
                <CheckBox Content="Controller Vibration" IsChecked="{Binding VibrationEnabled}" Margin="0,4"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
