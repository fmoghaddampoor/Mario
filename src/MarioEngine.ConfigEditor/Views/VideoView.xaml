<UserControl x:Class="MarioEngine.ConfigEditor.Views.VideoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="RESOLUTION" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Width:" Margin="0,0,12,8" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Width}" Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Height:" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Height}" Style="{StaticResource DarkTextBox}"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="DISPLAY" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <CheckBox Content="Fullscreen" IsChecked="{Binding Fullscreen}" Margin="0,4"/>
                <CheckBox Content="Vertical Sync (VSync)" IsChecked="{Binding VSync}" Margin="0,4"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="FPS Cap:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox SelectedValue="{Binding FpsCap}" SelectedValuePath="Tag" Style="{StaticResource DarkCombo}">
                        <ComboBoxItem Content="30" Tag="30"/><ComboBoxItem Content="60" Tag="60" IsSelected="True"/>
                        <ComboBoxItem Content="120" Tag="120"/><ComboBoxItem Content="144" Tag="144"/><ComboBoxItem Content="Unlimited" Tag="0"/>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="MSAA:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox SelectedValue="{Binding MsaaSamples}" SelectedValuePath="Tag" Style="{StaticResource DarkCombo}">
                        <ComboBoxItem Content="Off" Tag="0" IsSelected="True"/><ComboBoxItem Content="2x" Tag="2"/>
                        <ComboBoxItem Content="4x" Tag="4"/><ComboBoxItem Content="8x" Tag="8"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
