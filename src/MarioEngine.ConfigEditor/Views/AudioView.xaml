<UserControl x:Class="MarioEngine.ConfigEditor.Views.AudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="VOLUME" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <TextBlock Text="Master Volume" Style="{StaticResource FieldLabel}"/>
                <Slider Value="{Binding MasterVolumePercent}" Minimum="0" Maximum="100" TickFrequency="10"/>
                <TextBlock Text="Music Volume" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                <Slider Value="{Binding MusicVolumePercent}" Minimum="0" Maximum="100" TickFrequency="10"/>
                <TextBlock Text="SFX Volume" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                <Slider Value="{Binding SfxVolumePercent}" Minimum="0" Maximum="100" TickFrequency="10"/>
            </StackPanel>
        </Border>
        <Border Style="{StaticResource GroupBox}">
            <StackPanel>
                <TextBlock Text="LOG SERVERS" FontSize="13" FontWeight="Bold" Foreground="#8899AA" Margin="0,0,0,10"/>
                <TextBlock Text="Seq URL (optional)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding SeqUrl}" Style="{StaticResource DarkTextBox}"/>
                <TextBlock Text="Grafana Loki URL (optional)" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                <TextBox Text="{Binding LokiUrl}" Style="{StaticResource DarkTextBox}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
