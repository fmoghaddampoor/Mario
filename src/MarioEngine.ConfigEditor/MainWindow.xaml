<Window x:Class="MarioEngine.ConfigEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MarioEngine.ConfigEditor.Views"
        Title="Mario Game Configurator"
        Width="700" Height="550"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        FontFamily="Segoe UI, sans-serif"
        TextElement.Foreground="#E0E0E0">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F3460" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="GAME CONFIGURATOR" FontSize="20" FontWeight="Bold" Foreground="#E94560" VerticalAlignment="Center"/>
                <TextBlock Text="Super Mario Engine" FontSize="12" Foreground="#667799" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" BorderThickness="1">
            <TabItem Header="VIDEO"><views:VideoView/></TabItem>
            <TabItem Header="AUDIO"><views:AudioView/></TabItem>
            <TabItem Header="INPUT"><views:InputView/></TabItem>
            <TabItem Header="GAMEPLAY"><views:GameplayView/></TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#0F3460" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="#667799" VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="1" Content="RESET" Command="{Binding ResetDefaultsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="SAVE" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryActionButton}" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="CLOSE" Command="{Binding CloseWindowCommand}" Style="{StaticResource PrimaryActionButton}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
